rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if owns(uid);

      match /{document=**} {
        allow read, create, update, delete: if owns(uid);
      }
    }

    match /students/{uid} {
      allow read, create, update, delete: if owns(uid);

      match /{document=**} {
        allow read, create, update, delete: if owns(uid);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
